{
    "logLevel": 1,
    "registryCacheDir": "/var/lib/dadi/registryfs_cache",
    "registryCacheSizeGB": 4,
    "credentialFilePath": "/var/lib/aliyun-acr/.acceleration-suite/config.json",
    "ioEngine": 1,
    "download": {
        "enable": true,
        "delay": 1200,
        "maxMBps": 20
    },
    "enableAudit": true,
    "auditPath": "/var/log/overlaybd-audit.log",
    "p2p": {
        "enable": true,
        "ip": "127.0.0.1",
        "port": 9877,
        "timeout": 10
    },
    "checksumPath": "/var/lib/dadi/checksum"
}
